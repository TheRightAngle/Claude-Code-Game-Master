#!/bin/bash
# custom-stats post-hook for dm-time.sh
# Called AFTER CORE updates time. Reads --elapsed from args and ticks custom stats.

MODULE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

ELAPSED=""
SLEEPING=false
while [ $# -gt 0 ]; do
    case "$1" in
        --elapsed)
            ELAPSED="${2:-}"
            shift 2
            ;;
        --sleeping)
            SLEEPING=true
            shift
            ;;
        *)
            shift
            ;;
    esac
done

[ -n "$ELAPSED" ] || exit 0

if [ "$SLEEPING" = true ]; then
    bash "$MODULE_DIR/tools/dm-survival.sh" tick --elapsed "$ELAPSED" --sleeping
else
    bash "$MODULE_DIR/tools/dm-survival.sh" tick --elapsed "$ELAPSED"
fi
